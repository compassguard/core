# Compass MCP Guard env example
# Copy only the variables you need into .env.local or your deployment provider.
# Do not commit real secrets.

# Solana network
SOLANA_RPC_URL=https://api.devnet.solana.com

# Anchor program used by back/services/onchainApproval.ts.
# See docs/onchain-deployments.md for the latest devnet program ID.
AGENT_ACTION_GUARD_PROGRAM_ID=

# Optional wallet-safety attestor keypair.
# Prefer the *_FILE variant locally so key material is not embedded in shell history.
WALLET_SAFETY_ATTESTOR_SECRET_KEY_FILE=
WALLET_SAFETY_ATTESTOR_SECRET_KEY=

# Optional devnet quote fallback used by priceProviders/orcaUsdcSol.ts when allow_fallback=true.
FALLBACK_SOL_USD_PRICE=140
