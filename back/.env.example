# Compass MCP Guard backend env example
# Copy the variables you need into your local .env file. Do not commit real secrets.

# Solana network
# Only devnet is supported by the current MCP Guard backend.
SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional legacy-compatible fallback name read by solanaNetworkConfig.ts.
# Prefer SOLANA_RPC_URL in new Compass MCP Guard code.
VITE_HELIUS_RPC_URL=

# Devnet mints / token program. Defaults are embedded in back/services/solanaNetworkConfig.ts,
# so these are usually only needed for local test overrides.
DEVNET_SOL_MINT=So11111111111111111111111111111111111111112
DEVNET_USDC_MINT=BRjpCHtyQLNCo8gqRUr8jtdAj5AjPYQaoqbvcZiHok1k
SOLANA_TOKEN_PROGRAM_ID=TokenkegQfeZyiNwAJbNbGKPFXCWuBvf9Ss623VQ5DA

# Anchor program used by back/services/onchainApproval.ts.
# See docs/onchain-deployments.md for the latest devnet program ID.
AGENT_ACTION_GUARD_PROGRAM_ID=

# Optional attestor keypair for wallet-safety attestations.
# Prefer the *_FILE variant locally so key material is not embedded in shell history.
WALLET_SAFETY_ATTESTOR_SECRET_KEY_FILE=
WALLET_SAFETY_ATTESTOR_SECRET_KEY=

# Optional quote fallback used by priceProviders/orcaUsdcSol.ts when allow_fallback=true.
FALLBACK_SOL_USD_PRICE=140
